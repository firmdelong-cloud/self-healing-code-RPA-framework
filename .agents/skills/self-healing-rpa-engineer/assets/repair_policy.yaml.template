retry:
  max_attempts: 1
  delay_seconds: 0
repair_scope:
  scope_type: selector_only
  allowed_files:
    - example_skills/{skill_id}/selectors.yaml
  allowed_selector_refs:
    - submit_button
  must_not_touch_other_steps: true
  must_not_touch_runtime: true
sandbox:
  required: true
  command:
    - python
    - -m
    - pytest
    - example_skills/{skill_id}/tests/test_skill.py
