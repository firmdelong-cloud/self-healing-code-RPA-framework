id: "{skill_id}"
name: "{skill_name}"
version: 0.1.0
description: "Autogenerated RPA Skill scaffold for {skill_name}."
entrypoint: main.py
selectors: selectors.yaml
repair_policy: repair_policy.yaml
inputs:
  keyword:
    type: string
    default: demo
outputs:
  page_title:
    type: string
steps:
  - id: open_page
    type: goto
    goal: Open the starting page for this Skill.
    url: "{{{{{fixture_placeholder}}}}}"

  - id: wait_for_page_title
    type: wait_for
    goal: Wait for the page title to be visible.
    selector_ref: {selector_ref}

  - id: extract_page_title
    type: extract_text
    goal: Extract the page title into Skill outputs.
    selector_ref: {selector_ref}
    output_key: page_title
